CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5005
PORT=5005

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kuhedu_practice

# Only needed to run `npm run promote:content` from server/ -- pushes locally
# reviewed/approved pipeline content to production. Leave unset otherwise;
# the script refuses to run without it unless --dry-run is passed.
PRODUCTION_DATABASE_URL=

JWT_SECRET=replace_with_a_long_random_secret
SESSION_SECRET=replace_with_another_long_random_secret

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5005/api/auth/google/callback

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MODEL_MINI=gpt-5.4-mini
OPENAI_MODEL_LAYER_1=gpt-5.4-mini
OPENAI_MODEL_LAYER_2=gpt-5.4-mini
OPENAI_MODEL_LAYER_3=gpt-5.4-mini
OPENAI_MODEL_LAYER_4=gpt-5.4-mini
OPENAI_MODEL_LAYER_5=gpt-5.4-mini
OPENAI_MODEL_LAYER_6=gpt-5.4-mini
OPENAI_MODEL_LAYER_7=gpt-5.4-mini

# Azure OpenAI support
# This pipeline example maps every layer to the same Azure deployment.
AZURE_OPENAI_ENDPOINT=https://stemlab-pipeline-resource.services.ai.azure.com/openai/v1/responses
AZURE_OPENAI_API_KEY=your_azure_ai_key_here
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT_GPT54_MINI=gpt-5.4-mini

# Memory-hook image generation (Admin Workbench "Memory" tab). Requires a
# separate image-capable model (e.g. gpt-image-1 or dall-e-3) deployed under
# the SAME Azure OpenAI resource above -- the chat deployment does not cover
# this. Leave blank until that deployment exists; the feature fails with a
# clear "not configured" message until then, it does not crash anything.
AZURE_OPENAI_DEPLOYMENT_IMAGE=
# Only needed if the image deployment requires a different api-version than
# AZURE_OPENAI_API_VERSION above (uncommon, but Azure's image-generation API
# versions have sometimes diverged from chat-completions ones).
AZURE_OPENAI_IMAGE_API_VERSION=

# DeepSeek (OpenAI-compatible) support
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
# Grading model for the student concept-practice capture feature (the
# camera-capture question+answer AI-grading flow under AI Tutor). Reuses
# DEEPSEEK_API_KEY/DEEPSEEK_API_BASE_URL above.
DEEPSEEK_MODEL_PRO=

# Google Gemini (OpenAI-compatible) support -- used for handwritten-note OCR
# on language-arts subjects (English/Hindi/Bengali), where non-Latin-script
# recognition quality matters more than on the default model. Note the key
# name is GEMINIAPI_KEY (no underscore before API), not GEMINI_API_KEY.
# "-latest" model aliases are recommended over pinned versions (e.g.
# gemini-2.5-flash) -- Google has been known to retire pinned model IDs for
# newer API keys with a 404, while the alias keeps resolving to a live model.
GEMINIAPI_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest
# Vision OCR model for the student concept-practice capture feature (must be
# a vision-capable Gemini model for this key). Reuses GEMINIAPI_KEY above.
GEMINI_VISION_MODEL=gemini-flash-latest

# AI Tutor live voice (Gemini Live API) -- reuses GEMINIAPI_KEY above.
# GEMINI_VOICE_MODEL MUST be verified live against that key's available
# models before setting it here (GET .../v1alpha/models?key=<key> and
# confirm bidiGenerateContent support) -- do not assume GEMINI_MODEL above
# is Live-capable, different keys have different available Live models.
GEMINI_VOICE_MODEL=
# One of Gemini's prebuilt TTS voice names; defaults to "Achird" if unset.
GEMINI_VOICE_NAME=
# Optional BCP-47 code -- most values are REJECTED by the live model; leave
# unset unless verified working for this specific key.
GEMINI_VOICE_LANGUAGE=

# AI Tutor avatar face (SpatialReal, third-party vendor -- requires its own
# account/credentials, separate from the vars above). Feature falls back to
# local audio playback until these are set.
SPATIALREAL_API_KEY=
SPATIALREAL_APP_ID=
SPATIALREAL_AVATAR_ID=
SPATIALREAL_REGION=ap-northeast


